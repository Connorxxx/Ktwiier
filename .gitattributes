# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.gradle text eol=lf
*.gradle.kts text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Scripts
*.sh text eol=lf
*.bash text eol=lf
gradlew text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
gradlew.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.flv binary
*.fla binary
*.swf binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.eot binary
*.woff binary
*.woff2 binary
*.pyc binary
*.pdf binary
*.ez binary
*.bz2 binary
*.swp binary
*.jar binary
*.so binary
*.dylib binary
*.dll binary
*.exe binary
*.class binary
*.dex binary
*.ap_ binary
*.apk binary
*.aab binary
*.ipa binary

# iOS/macOS
*.pbxproj binary merge=union
*.xcworkspacedata binary merge=union
*.xcscheme binary merge=union
